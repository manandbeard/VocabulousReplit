{
  "aesthetic": "minimalist_academic",
  "canvas": {
    "backgroundColor": "#FFFFFF",
    "blendMode": "multiply",
    "opacity": 0.8
  },
  "elements": {
    "dots": {
      "count": 150,
      "minSize": 1,
      "maxSize": 3,
      "color": "#E2E8F0",
      "behavior": "gentle_float"
    },
    "lines": {
      "connectionProbability": 0.05,
      "maxConnectionsPerDot": 2,
      "thickness": 0.5,
      "color": "#94A3B8",
      "drawDurationMs": 2000,
      "holdDurationMs": 5000,
      "fadeDurationMs": 1500
    }
  },
  "interactivity": {
    "onHover": {
      "effect": "subtle_repel",
      "radius": 100
    },
    "onScroll": "slow_parallax_down"
  }
}
